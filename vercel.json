{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @workspace/data-career-platform run build",
  "outputDirectory": "artifacts/data-career-platform/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://placeholder-replace-with-api-url.example.com/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "BASE_PATH": "/",
    "PORT": "3000"
  },
  "build": {
    "env": {
      "BASE_PATH": "/",
      "PORT": "3000"
    }
  }
}
